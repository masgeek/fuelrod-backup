{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeDisabled"
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "schedule": [
    "before 6am on monday"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "labels": [
        "automerge"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "labels": [
        "breaking-change"
      ],
      "prPriority": 1
    },
    {
      "matchManagers": [
        "pip_requirements",
        "poetry"
      ],
      "groupName": "Python dependencies",
      "labels": [
        "python"
      ]
    }
  ]
}