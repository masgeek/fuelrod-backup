# fuelrod-backup example config
# Copy this file to .backup and customize values.
#
# Two config styles are supported:
#
#   Single-engine  — set DB_TYPE + generic DB_* keys (original behaviour)
#   Multi-engine   — set engine-prefixed PG_* / MY_* / MS_* keys and run
#                    `fuelrod-backup backup --all-engines` to back up all
#                    configured engines in parallel.
#
# In multi-engine mode DB_TYPE / DB_* keys are ignored.
# Shared settings (BASE_DIR, COMPRESS_FILE, KEEP_DAYS, CONNECTION_TIMEOUT)
# are always read without a prefix.

# ── Shared ──────────────────────────────────────────────────────────────────
BASE_DIR=./db-backup
COMPRESS_FILE=true
KEEP_DAYS=7
CONNECTION_TIMEOUT=30

# ══════════════════════════════════════════════════════════════════════════════
# SINGLE-ENGINE MODE  (comment out to use multi-engine mode below)
# ══════════════════════════════════════════════════════════════════════════════

# Engine: postgres | mariadb | mssql
DB_TYPE=postgres

# Connection
DB_USERNAME=postgres
DB_PASSWORD=change_me
DB_HOST=127.0.0.1
DB_PORT=5432

# Docker mode
USE_DOCKER=true
SERVICE=postgres

# PostgreSQL commands
PG_DUMP_CMD=pg_dump
PG_RESTORE_CMD=pg_restore

# MariaDB commands
MYSQL_DUMP_CMD=mariadb-dump
MYSQL_CMD=mysql

# MSSQL backup location inside container
MSSQL_BACKUP_DIR=/var/opt/mssql/backups

# ══════════════════════════════════════════════════════════════════════════════
# MULTI-ENGINE MODE  (run: fuelrod-backup backup --all-engines)
# Only engines with credentials set are activated.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL (PG_) ─────────────────────────────────────────────────────────
#PG_USERNAME=postgres
#PG_PASSWORD=change_me
#PG_HOST=127.0.0.1
#PG_PORT=5432
#PG_SERVICE=postgres
#PG_USE_DOCKER=true
#PG_DUMP_CMD=pg_dump
#PG_RESTORE_CMD=pg_restore
#PG_CMD=psql

# ── MariaDB / MySQL (MY_) ────────────────────────────────────────────────────
#MY_USERNAME=root
#MY_PASSWORD=change_me
#MY_HOST=127.0.0.1
#MY_PORT=3306
#MY_SERVICE=mariadb
#MY_USE_DOCKER=true
#MY_DUMP_CMD=mariadb-dump
#MY_CMD=mysql

# ── MSSQL (MS_) ──────────────────────────────────────────────────────────────
#MS_USERNAME=sa
#MS_PASSWORD=change_me
#MS_HOST=127.0.0.1
#MS_PORT=1433
