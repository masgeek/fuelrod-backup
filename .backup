# fuelrod-backup configuration
# Generated by: fuelrod-backup init
#
# Place this file in the directory you run fuelrod-backup from,
# or pass it explicitly with: fuelrod-backup --config /path/to/.backup

DB_TYPE=postgres

# ── Connection ──────────────────────────────────────────────────
PG_USERNAME=fuelrod
PG_PASSWORD=fuelrod
PG_HOST=127.0.0.1
PG_PORT=5432

# ── Docker ──────────────────────────────────────────────────────
USE_DOCKER=false
SERVICE=postgres

# ── Backup storage ──────────────────────────────────────────────
BASE_DIR=D:\Dev\tools\proxy-tool\db-backup
COMPRESS_FILE=true
KEEP_DAYS=7

# ── Timeouts ────────────────────────────────────────────────────
CONNECTION_TIMEOUT=10

# ── PostgreSQL binaries (on PATH or inside container) ───────────
PG_DUMP_CMD=pg_dump
PG_RESTORE_CMD=pg_restore
